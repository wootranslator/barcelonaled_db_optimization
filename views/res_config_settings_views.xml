<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.barcelonaled.db.optimization</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='companies_setting_container']" position="after">
                <block title="Optimización Base de Datos (Technical)" name="db_optimization_setting_container" groups="base.group_system">
                    
                    <!-- Configuración Global -->
                    <setting string="Configuración Global" help="Define si los índices creados por este módulo deben permanecer en la base de datos PostgreSQL de forma permanente.">
                        <field name="keep_indices_on_uninstall"/>
                        <span class="o_form_label">Mantener índices tras desinstalar el módulo</span>
                    </setting>

                    <hr class="mt32 mb16" style="border-top: 1px dashed #dee2e6;"/>

                    <!-- Planificación (Cron) -->
                    <setting string="Planificación Automática" help="Tarea semanal preventiva.">
                        <div class="row mt16">
                            <span class="col-lg-3 o_form_label">Activar Cron</span>
                            <div class="col-lg-9">
                                <field name="cron_active"/>
                            </div>
                        </div>
                        <div class="row mt8" invisible="not cron_active">
                            <label for="cron_interval_number" string="Frecuencia" class="col-lg-3 o_light_label ps-4"/>
                            <div class="col-lg-9">
                                <field name="cron_interval_number" class="oe_inline"/>
                                <field name="cron_interval_type" class="oe_inline ms-2"/>
                            </div>
                        </div>
                    </setting>

                    <!-- Terminal de Logs (Novedad) -->
                    <setting string="Monitor de Estado (Tiempo Real)" help="Visualiza el progreso de las tareas de indexado.">
                        <div class="mt-3 p-3 bg-dark text-white rounded font-monospace" style="min-height: 200px; max-height: 300px; overflow-y: auto; font-size: 11px; border: 2px solid #333;">
                            <field name="optimization_log_ids" nolabel="1" readonly="1">
                                <list no_open="1" create="0" delete="0" edit="0" decoration-success="type == 'success'" decoration-info="type == 'info'" decoration-danger="type == 'error'" decoration-warning="type == 'warning'">
                                    <field name="create_date" string="Hora" widget="datetime" options="{'format': 'HH:mm:ss'}"/>
                                    <field name="message" string="Mensaje"/>
                                    <field name="type" column_invisible="True"/>
                                </list>
                            </field>
                            <div class="mt-2 text-center text-muted small" invisible="optimization_log_ids">
                                --- No hay logs recientes. Pulsa un botón para iniciar ---
                            </div>
                        </div>
                    </setting>

                    <!-- Botones de Acción -->
                    <setting string="Acciones Inmediatas" help="Lanzan las tareas que verás arriba en tiempo real.">
                        <div class="mt16">
                            <button name="action_apply_db_optimizations" string="Lanzar Mantenimiento" type="object" class="btn-primary me-2" icon="fa-play"/>
                            <button name="action_reindex_db_tables" string="Forzar Reindexado (Pesado)" type="object" class="btn-secondary" icon="fa-refresh" confirm="Esta operación reconstruye los índices. Consulta el terminal arriba para ver el progreso. ¿Deseas continuar?"/>
                        </div>
                    </setting>

                    <hr class="mt32 mb16" style="border-top: 1px solid #dee2e6; opacity: 0.5;"/>

                    <!-- Selección de Aplicaciones -->
                    <div class="row mt16">
                        <div class="col-12 col-lg-6">
                            <setting string="Inventario" help="Mejora albaranes y stock.valuation.">
                                <field name="opt_index_stock"/>
                            </setting>
                            <setting string="Ventas / TPV" help="Mejora pedidos y POS.">
                                <field name="opt_index_sale"/>
                            </setting>
                            <setting string="Contabilidad" help="Optimiza motor EDI y facturas.">
                                <field name="opt_index_accounting"/>
                            </setting>
                        </div>
                        <div class="col-12 col-lg-6">
                            <setting string="Contactos" help="Mejora búsquedas en Partner.">
                                <field name="opt_index_contact"/>
                            </setting>
                            <setting string="Técnico / Core" help="Mejora Chatter y Logs.">
                                <field name="opt_index_technical"/>
                            </setting>
                        </div>
                    </div>

                </block>
            </xpath>
        </field>
    </record>
</odoo>
