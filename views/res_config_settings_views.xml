<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.barcelonaled.db.optimization</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='companies_setting_container']" position="after">
                <block title="Optimización Base de Datos (Technical)" name="db_optimization_setting_container" groups="base.group_system">
                    
                    <setting string="Configuración Global" help="Define si los índices deben persistir tras la desinstalación.">
                        <field name="keep_indices_on_uninstall"/>
                        <span class="o_form_label">Mantener índices tras desinstalar el módulo</span>
                    </setting>

                    <hr class="mt32 mb16" style="border-top: 1px dashed #dee2e6;"/>

                    <!-- Planificación (Cron) -->
                    <setting string="Planificación Automática" help="Tarea preventiva semanal.">
                        <div class="row mt16">
                            <span class="col-lg-3 o_form_label">Activar Cron</span>
                            <div class="col-lg-9">
                                <field name="cron_active"/>
                            </div>
                        </div>
                        <div class="row mt8" invisible="not cron_active">
                            <label for="cron_interval_number" string="Frecuencia" class="col-lg-3 o_light_label ps-4"/>
                            <div class="col-lg-9">
                                <field name="cron_interval_number" class="oe_inline"/>
                                <field name="cron_interval_type" class="oe_inline ms-2"/>
                            </div>
                        </div>
                    </setting>

                    <!-- MONITOR DE ESTADO (REDiseño con HTML) -->
                    <setting string="Monitor de Estado" help="Progreso en tiempo real.">
                        <div class="w-100 mt-2 d-flex justify-content-between align-items-center">
                             <span class="text-muted small">Haz clic para actualizar los últimos eventos:</span>
                             <button name="action_refresh_optimization_logs" string="Actualizar Monitor" type="object" class="btn btn-secondary btn-sm" icon="fa-refresh"/>
                        </div>
                        <div class="mt-2 p-3 bg-dark text-white rounded shadow-sm" style="min-height: 250px; max-height: 400px; overflow-y: auto; border: 2px solid #222;">
                            <field name="optimization_terminal" widget="html" nolabel="1" readonly="1"/>
                        </div>
                    </setting>

                    <!-- Botones de Acción -->
                    <setting string="Acciones Inmediatas" help="Lanzan las tareas en segundo plano.">
                        <div class="mt16">
                            <button name="action_apply_db_optimizations" string="Lanzar Mantenimiento" type="object" class="btn-primary me-2" icon="fa-play"/>
                            <button name="action_reindex_db_tables" string="Forzar Reindexado (Pesado)" type="object" class="btn-secondary" icon="fa-refresh" confirm="Esta operación se ejecutará asíncronamente en segundo plano. Puedes cerrar esta ventana y volver más tarde para ver el terminal."/>
                        </div>
                    </setting>

                    <hr class="mt32 mb16" style="border-top: 1px solid #dee2e6; opacity: 0.5;"/>

                    <!-- Selección de Aplicaciones -->
                    <div class="row mt16">
                        <div class="col-12 col-lg-6">
                            <setting string="Inventario" help="Optimiza stock.picking y movimientos.">
                                <field name="opt_index_stock"/>
                            </setting>
                            <setting string="Ventas / TPV" help="Optimiza origen de pedidos y POS.">
                                <field name="opt_index_sale"/>
                            </setting>
                            <setting string="Contabilidad" help="Facturas y motor EDI.">
                                <field name="opt_index_accounting"/>
                            </setting>
                        </div>
                        <div class="col-12 col-lg-6">
                            <setting string="Contactos" help="Búsquedas en grandes listas de clientes.">
                                <field name="opt_index_contact"/>
                            </setting>
                            <setting string="Técnico / Core" help="Chatter y Logs de sistema.">
                                <field name="opt_index_technical"/>
                            </setting>
                        </div>
                    </div>

                </block>
            </xpath>
        </field>
    </record>
</odoo>
