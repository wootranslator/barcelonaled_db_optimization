<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.barcelonaled.db.optimization</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='companies_setting_container']" position="after">
                <block title="Optimización Base de Datos (Technical)" name="db_optimization_setting_container" groups="base.group_system">
                    
                    <!-- Opción Global de Persistencia -->
                    <setting string="Configuración Global" help="Define si los índices creados por este módulo deben permanecer en la base de datos PostgreSQL de forma permanente, incluso si el módulo es desinstalado en el futuro. Útil para entornos de producción donde no quieres arriesgarte a perder rendimiento.">
                        <field name="keep_indices_on_uninstall"/>
                        <span class="o_form_label">Mantener índices en PostgreSQL tras desinstalar el módulo</span>
                    </setting>

                    <hr class="mt32 mb16" style="border-top: 1px dashed #dee2e6;"/>

                    <!-- Planificación (Cron) -->
                    <setting string="Planificación Automática" help="Configura la tarea automática que revisa que todos los índices de optimización existan y estén en buen estado. Se recomienda una ejecución semanal en horas de baja carga.">
                        <div class="row mt16">
                            <span class="col-lg-3 o_form_label">Activar Cron</span>
                            <div class="col-lg-9">
                                <field name="cron_active"/>
                            </div>
                        </div>
                        <div class="row mt8" invisible="not cron_active">
                            <span class="col-lg-3 o_form_label">Frecuencia</span>
                            <div class="col-lg-9 text-muted italic">
                                <span>Intervalo en el cual se ejecutará el mantenimiento preventivo.</span>
                            </div>
                            <label for="cron_interval_number" string="Cada" class="col-lg-3 o_light_label ps-4"/>
                            <div class="col-lg-9 mt-2">
                                <field name="cron_interval_number" class="oe_inline"/>
                                <field name="cron_interval_type" class="oe_inline ms-2"/>
                            </div>
                        </div>
                        <div class="row mt8" invisible="not cron_active">
                            <span class="col-lg-3 o_form_label">Gestión de Tiempos</span>
                            <div class="col-lg-9">
                                <div class="mt-2">
                                    <span class="text-muted">Próxima: </span><field name="cron_nextcall" class="oe_inline"/>
                                </div>
                                <div class="mt-1">
                                    <span class="text-muted">Última: </span><field name="cron_lastcall" class="oe_inline" readonly="1"/>
                                </div>
                            </div>
                        </div>
                    </setting>

                    <!-- Botones de Acción -->
                    <setting string="Acciones Inmediatas" help="Botones para ejecutar manualmente las tareas de optimización. 'Lanzar Mantenimiento' crea los índices que falten. 'Forzar Reindexado' reconstruye los índices existentes (operación lenta) para optimizar el almacenamiento en disco y la velocidad de acceso tras borrados masivos.">
                        <div class="mt16">
                            <button name="action_apply_db_optimizations" string="Lanzar Mantenimiento" type="object" class="btn-primary me-2" icon="fa-play"/>
                            <button name="action_reindex_db_tables" string="Forzar Reindexado (Pesado)" type="object" class="btn-secondary" icon="fa-refresh" confirm="Esta operación reconstruye los índices desde cero. Es una operación intensiva para el disco y la CPU. ¿Deseas continuar?"/>
                        </div>
                    </setting>

                    <hr class="mt32 mb16" style="border-top: 1px solid #dee2e6; opacity: 0.5;"/>

                    <!-- Selección de Aplicaciones a Optimizar (Toggles) -->
                    <div class="row mt16">
                        <div class="col-12 col-lg-6">
                            <setting string="Inventario" help="Añade índices a stock.picking (albaranes), stock.move (movimientos) y stock.valuation.layer. Resuelve la lentitud en la carga de listas de transferencias y el cálculo de stock disponible.">
                                <field name="opt_index_stock"/>
                            </setting>
                            <setting string="Ventas / TPV" help="Optimiza búsquedas por origen en líneas de pedido y acelera la relación entre el Punto de Venta y los pedidos de venta.">
                                <field name="opt_index_sale"/>
                            </setting>
                            <setting string="Contabilidad" help="Optimiza el motor de documentos EDI y el filtrado por estado en facturas (account.move). Crucial si gestionas un volumen alto de facturas electrónicas.">
                                <field name="opt_index_accounting"/>
                            </setting>
                        </div>
                        <div class="col-12 col-lg-6">
                            <setting string="Contactos" help="Añade índices compuestos para los rangos de cliente y proveedor. Mejora drásticamente la velocidad al buscar contactos o abrir el autocompletado en pedidos si tienes más de 100,000 registros en res.partner.">
                                <field name="opt_index_contact"/>
                            </setting>
                            <setting string="Técnico / Core" help="Mejora el rendimiento del Chatter (reacciones de mensajes) y las consultas al log de Odoo (ir.logging). También acelera la resolución de dependencias entre módulos.">
                                <field name="opt_index_technical"/>
                            </setting>
                        </div>
                    </div>

                </block>
            </xpath>
        </field>
    </record>
</odoo>
